      title: "\u30B9\u30D7\u30EA\u30C3\u30C8\u30B9\u30BF\u30C3\u30AF"
      description: "\u6B21\u306E\u30B9\u30ED\u30C3\u30C8\u304C\u7A7A\u304F\u307E\u3067\u3001\u30B9\u30BF\u30C3\u30AF\u3092\u500B\u3005\u306E\u30A2\u30A4\u30C6\u30E0\u306B\u5206\u5272\u3057\u307E\u3059\u3002"
    - m_language:
        m_address:
          m_low: -2052239290651699458
