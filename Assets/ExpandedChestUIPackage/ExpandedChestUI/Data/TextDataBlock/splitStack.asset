    - m_language:
        m_address:
          m_low: -998452581336238672
          m_high: -1236628366252422438
      title: "\u0420\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0439
        \u0441\u0442\u0435\u043A"
      description: "\u0420\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u0435 \u0441\u0442\u043E\u043F\u043A\u0443
        \u043D\u0430 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B,
        \u043F\u043E\u043A\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
        \u0441\u043B\u043E\u0442 \u043D\u0435 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0435\u0442
        \u0431\u044B\u0442\u044C \u043F\u0443\u0441\u0442\u044B\u043C."
    - m_language:
        m_address:
          m_low: 555117963105384372
          m_high: 3194402766475108890
      title: Dividir Pila
      description: "Divide la pila en elementos individuales, hasta que el siguiente
        espacio no est\xE9 vac\xEDo."
    - m_language:
        m_address:
          m_low: 7837645069971566515
          m_high: 4238944138262099067
      title: "\u0E2A\u0E1B\u0E25\u0E34\u0E15 \u0E2A\u0E41\u0E15\u0E47\u0E04"
      description: "\u0E41\u0E22\u0E01\u0E01\u0E2D\u0E07\u0E2A\u0E34\u0E48\u0E07\u0E02\u0E2D\u0E07\u0E2D\u0E2D\u0E01\u0E40\u0E1B\u0E47\u0E19\u0E0A\u0E34\u0E49\u0E19\u0E46
        \u0E08\u0E19\u0E01\u0E27\u0E48\u0E32\u0E0A\u0E48\u0E2D\u0E07\u0E16\u0E31\u0E14\u0E44\u0E1B\u0E08\u0E30\u0E44\u0E21\u0E48\u0E27\u0E48\u0E32\u0E07\u0E40\u0E1B\u0E25\u0E48\u0E32"
    - m_language:
        m_address:
          m_low: 7031320391619404414
          m_high: 5017443214120506826
      title: "\u0420\u043E\u0437\u0434\u0456\u043B\u0435\u043D\u0438\u0439 \u0441\u0442\u0435\u043A"
      description: "\u0420\u043E\u0437\u0434\u0456\u043B\u0456\u0442\u044C \u0441\u0442\u0435\u043A
        \u043D\u0430 \u043E\u043A\u0440\u0435\u043C\u0456 \u0435\u043B\u0435\u043C\u0435\u043D\u0442\u0438,
        \u0434\u043E\u043A\u0438 \u043D\u0430\u0441\u0442\u0443\u043F\u043D\u0438\u0439
        \u0441\u043B\u043E\u0442 \u043D\u0435 \u0441\u0442\u0430\u043D\u0435 \u043F\u043E\u0440\u043E\u0436\u043D\u0456\u043C."
